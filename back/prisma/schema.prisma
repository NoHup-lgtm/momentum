// momentum · schema.prisma
// stack: NestJS + Prisma 7 + Neon (PostgreSQL)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL definida via prisma.config.ts → process.env.DATABASE_URL
}

// ══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════════════════════

enum AuthProvider {
  GITHUB
}

// ── Progressão individual ─────────────────────────────────────────────────────
enum UserRank {
  INIT
  BUILD
  DEPLOY
  SENIOR
  ARCHITECT
  LEGEND
}

// ── Progressão coletiva da squad ──────────────────────────────────────────────
// Rank permanente da squad — sobe com conquistas coletivas, não com sprint
enum SquadRank {
  GARAGE
  BOOTSTRAPPED
  STARTUP
  UNICORN
  BIG_TECH
  SILICON_VALLEY
}

enum SquadRole {
  OWNER
  MEMBER
}

// ── Assinatura ────────────────────────────────────────────────────────────────
enum SubscriptionPlan {
  PRO   // Freezes ilimitados, 30 gems/mês, baú épico, analytics pessoal
  MAX   // Tudo do Pro + 100 gems/mês, múltiplas squads, torneios, badge animado
}

enum SubscriptionBilling {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIAL      // Período grátis de 14 dias
  ACTIVE
  PAST_DUE   // Pagamento falhou mas ainda no período de graça
  CANCELED
  EXPIRED
}

// ── Cosméticos ────────────────────────────────────────────────────────────────
enum CosmeticCategory {
  HAT
  SHIRT
  GLASSES
  ACCESSORY
  BACKGROUND
}

enum CosmeticRarity {
  COMMON
  RARE
  PREMIUM
  LEGENDARY
}

// CHEST adicionado: cosméticos podem vir de baús
enum CosmeticObtainedSource {
  PURCHASED_COINS
  PURCHASED_GEMS
  ACHIEVEMENT_REWARD
  CHEST_REWARD        // Drop de baú
  EVENT_REWARD
}

// ── Conquistas ────────────────────────────────────────────────────────────────
enum AchievementCategory {
  STREAK       // Ofensiva (dias consecutivos)
  COMMIT       // Volume de commits
  PR           // Pull Requests e colaboração
  RANK         // Atingir determinado rank
  SOCIAL       // Posição e interação na squad
  COLLECTION   // Itens comprados ou ganhos
  HIDDEN       // Easter eggs — invisíveis até serem desbloqueados
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

// ── Métricas — usadas em desafios e conquistas ────────────────────────────────
enum MetricType {
  DAILY_ACTIVITIES           // Atividades em um único dia (commits, PRs…)
  DAILY_COMMITS              // Commits especificamente em um dia
  DAILY_PRS                  // Pull Requests em um único dia
  STREAK_DAYS                // Dias consecutivos com atividade
  MAX_STREAK                 // Maior streak atingida (all-time)
  WEEKLY_COMMITS             // Commits na semana corrente
  TOTAL_XP                   // XP acumulado total (conquistas de longo prazo)
  OPEN_SOURCE_CONTRIBUTIONS  // Contribuições para repos de terceiros
}

// ── Tipo de atividade do GitHub ───────────────────────────────────────────────
// Extensível: hoje só COMMIT ativa streak, mas PR e review podem no futuro
enum ActivityType {
  COMMIT          // Push com commit(s) — ativa a ofensiva
  PULL_REQUEST    // PR aberto ou mergeado
  CODE_REVIEW     // Review submetido
}

// ── Fontes de XP ──────────────────────────────────────────────────────────────
enum XpSource {
  DAILY_ACTIVITY      // XP por atividade do dia (commit, PR, etc.)
  STREAK_MILESTONE    // Bônus por marco de streak (7d, 30d, 100d…)
  DAILY_CHALLENGE     // Desafio diário concluído
  ACHIEVEMENT         // Conquista desbloqueada
  RANK_UP_BONUS       // Bônus ao subir de rank
  SQUAD_BONUS         // Bônus por posição no ranking semanal
  CHECKIN             // XP de check-in manual (qualidade do dia)
}

// ── Fontes de Coins ───────────────────────────────────────────────────────────
enum CoinSource {
  DAILY_ACTIVITY      // Coins por atividade do dia
  DAILY_CHALLENGE     // Desafio diário
  ACHIEVEMENT         // Conquista
  STREAK_MILESTONE    // Marco de streak
  SQUAD_TOP3          // Top 3 no ranking semanal
  PURCHASE_ITEM       // Compra de item na loja (valor negativo)
}

// ── Fontes de Gems ────────────────────────────────────────────────────────────
enum GemSource {
  PURCHASE            // Dinheiro real via Stripe (referencia gem_purchases.id)
  SUBSCRIPTION        // Gems mensais incluídas no plano Pro/Max
  CHEST               // Drop de baú
  ACHIEVEMENT         // Recompensa de conquista
  DAILY_CHALLENGE     // Desafio que recompensa gems
  EVENT_REWARD        // Torneio ou evento especial
  PURCHASE_ITEM       // Gasto na loja (valor negativo)
}

// ── Status do streak freeze ───────────────────────────────────────────────────
enum FreezeStatus {
  ACTIVE    // Freeze ativo — ainda protegendo o dia
  CONSUMED  // Dia passou, freeze foi consumido com sucesso
}

// ── Baús ──────────────────────────────────────────────────────────────────────
enum ChestRarity {
  COMUM     // Madeira — drops básicos
  RARO      // Circuito — drops intermediários
  EPICO     // Void — drops raros
  LENDARIO  // Dourado — drops exclusivos
}

enum ChestSource {
  CHALLENGE     // Completar desafio diário
  ACHIEVEMENT   // Desbloquear conquista
  SUBSCRIPTION  // Baú mensal do plano Pro/Max
  EVENT         // Torneio ou evento especial
  SQUAD_REWARD  // Recompensa por posição no sprint da liga
}

enum ChestRewardType {
  XP
  COINS
  GEMS
  COSMETIC
}

// ── Liga (sprint competitivo) ─────────────────────────────────────────────────
// Nota: SquadRank é progressão permanente da squad.
// Liga é competição individual por XP ganho em cada sprint de 2 semanas.
enum FeedEventType {
  STREAK_MILESTONE     // Usuário bateu 7, 14, 30, 50 ou 100 dias
  LEVEL_UP             // Subiu de nível
  RANK_UP              // Subiu de rank (Init → Build, etc.)
  ACHIEVEMENT          // Desbloqueou conquista
  CHEST_LEGENDARY      // Abriu um baú lendário
  SQUAD_JOIN           // Novo membro entrou na squad
  LIGA_PROMOTED        // Subiu de liga (promovido)
  CHALLENGE_COMPLETED  // Concluiu desafio do dia
}

enum FeedVisibility {
  SQUAD   // Apenas membros da mesma squad veem
  GLOBAL  // Visível no feed público
}

// ══════════════════════════════════════════════════════════════════════════════
// MODELS
// ══════════════════════════════════════════════════════════════════════════════

// ── Waitlist da landing page ──────────────────────────────────────────────────
model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String?  // "hero" | "finalcta" — de qual seção da LP veio
  createdAt DateTime @default(now())

  @@map("waitlist")
}

// ── Usuário ───────────────────────────────────────────────────────────────────
model User {
  id           String       @id @default(uuid())

  // GitHub OAuth
  githubId     String       @unique  // ID numérico imutável da conta GitHub
  githubLogin  String       @unique  // username GitHub (ex: "dev_marcos")
  accessToken  String                // OAuth token — criptografar antes de persistir
  avatarUrl    String?               // Foto de perfil do GitHub
  email        String?      @unique  // Email público do GitHub

  // Exibição no app
  displayName  String?               // Nome customizável dentro do app
  avatarVariant Int         @default(0)   // Índice do pixel avatar (0–5)
  timezone     String       @default("America/Sao_Paulo")

  // Auth
  authProvider AuthProvider @default(GITHUB)

  // Progressão
  rank         UserRank     @default(INIT)
  level        Int          @default(1)   // Nível numérico baseado em totalXp
  totalXp      Int          @default(0)

  // Moedas
  coins        Int          @default(0)
  gems         Int          @default(0)

  // Ofensiva
  currentStreak    Int       @default(0)
  maxStreak        Int       @default(0)
  lastActivityDate DateTime? @db.Date  // Última data com atividade válida para streak
  streakFreezes    Int       @default(1)

  // Plano de assinatura (cache denormalizado — fonte da verdade é Subscription)
  // null = free. Atualizado pelo webhook do Stripe ao confirmar/cancelar.
  subscriptionPlan SubscriptionPlan?

  // Billing Stripe
  stripeCustomerId String?  @unique

  // Preferências de notificação
  notifyStreakReminder Boolean @default(true)   // Aviso antes de meia-noite
  notifySquadActivity  Boolean @default(true)   // Membro da squad commitou
  notifyRankUp         Boolean @default(false)  // Alguém subiu de rank na squad
  notifyWeeklyRecap    Boolean @default(true)   // Resumo semanal no domingo

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relacionamentos
  dailyActivities     DailyActivity[]
  processedEvents     ProcessedGithubEvent[]
  streakFreezeUsages  StreakFreezeUsage[]
  xpTransactions      XpTransaction[]
  coinTransactions    CoinTransaction[]
  gemTransactions     GemTransaction[]
  gemPurchases        GemPurchase[]
  subscription        Subscription?
  squadMemberships    SquadMember[]
  squadsOwned         Squad[]
  squadInvitesCreated SquadInvite[]
  devices             UserDevice[]
  cosmetics           UserCosmetic[]
  equippedCosmetics   UserEquippedCosmetic[]
  rankHistory         RankHistory[]
  achievements        UserAchievement[]
  achievementProgress AchievementProgress[]
  dailyChallenges     UserDailyChallenge[]
  chests              UserChest[]
  ligaParticipations  LigaParticipant[]
  feedEvents          FeedEvent[]

  @@map("users")
}

// ── Dispositivos do usuário (push notifications) ──────────────────────────────
model UserDevice {
  id         String   @id @default(uuid())
  userId     String
  pushToken  String   @unique  // Token Expo / FCM / APNS
  platform   String            // "ios" | "android"
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_devices")
}

// ── Atividade diária do usuário ───────────────────────────────────────────────
// Um registro por usuário por dia por tipo de atividade.
// Quando o usuário faz o 3º commit do dia: apenas incrementa `count`, não cria nova linha.
// Crescimento = usuários × dias ativos × tipos de atividade — linear e controlado.
//
// Lifecycle:
//   1. Webhook GitHub chega → verifica ProcessedGithubEvent (dedup)
//   2. UPSERT DailyActivity: cria se não existe, incrementa count se existe
//   3. Se primeira atividade do dia → atualiza User.lastActivityDate + recalcula streak
model DailyActivity {
  id           String       @id @default(uuid())
  userId       String
  date         DateTime     @db.Date      // Dia da atividade (ajustado por timezone + grace period)
  activityType ActivityType

  // Resumo do dia para este tipo de atividade
  count        Int          @default(1)   // Quantas vezes (commits, PRs, etc.)
  xpGained     Int          @default(0)   // XP total ganho neste dia por este tipo
  coinsGained  Int          @default(0)   // Coins totais ganhos
  keptStreak   Boolean      @default(false) // Esta atividade ativou/manteve a ofensiva do dia?

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, activityType])  // Um resumo por usuário por dia por tipo
  @@index([userId, date])                 // Query principal: "teve atividade hoje?"
  @@index([userId, keptStreak])           // Filtrar dias que mantiveram streak
  @@map("daily_activities")
}

// ── Eventos GitHub processados (deduplicação) ─────────────────────────────────
// Armazena apenas o ID do evento do GitHub para evitar processar o mesmo
// webhook duas vezes. Registros com mais de 30 dias podem ser deletados
// via cron — webhooks duplicados tardios não são uma preocupação real.
model ProcessedGithubEvent {
  eventId     String   @id           // GitHub Event ID (ex: "12345678901")
  userId      String
  activityType ActivityType
  processedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([processedAt])  // Para limpeza periódica: DELETE WHERE processedAt < now() - 30d
  @@map("processed_github_events")
}

// ── Uso de streak freeze ──────────────────────────────────────────────────────
model StreakFreezeUsage {
  id            String       @id @default(uuid())
  userId        String
  protectedDate DateTime     @db.Date     // Qual dia o freeze salvou
  status        FreezeStatus @default(ACTIVE)
  activatedAt   DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, protectedDate])  // Máximo 1 freeze por dia por usuário
  @@index([userId])
  @@map("streak_freeze_usages")
}

// ── Histórico de rank ─────────────────────────────────────────────────────────
// Cada linha = uma mudança de rank. Dispara a animação de rank-up no app.
// Permite mostrar no perfil: "virou Senior em 15 mai".
model RankHistory {
  id        String   @id @default(uuid())
  userId    String
  fromRank  UserRank
  toRank    UserRank
  changedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@map("rank_history")
}

// ── Histórico de XP ───────────────────────────────────────────────────────────
// Append-only. Nunca deletar. Fonte da verdade para auditoria de progressão.
model XpTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int               // Positivo = ganhou | Negativo = perdeu
  source      XpSource
  description String?           // "Ofensiva de 30 dias!" | "Top 1 na squad"
  referenceId String?           // ID do commit, achievement, etc. que gerou o XP
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

// ── Histórico de Coins ────────────────────────────────────────────────────────
model CoinTransaction {
  id          String     @id @default(uuid())
  userId      String
  amount      Int                // Positivo = ganhou | Negativo = gastou
  source      CoinSource
  description String?
  referenceId String?
  createdAt   DateTime   @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coin_transactions")
}

// ── Histórico de Gems ─────────────────────────────────────────────────────────
// Ledger completo de gems — cobre todos os fluxos de entrada e saída.
// Saldo real = SELECT SUM(amount) FROM gem_transactions WHERE userId = ?
// User.gems é cache denormalizado, atualizado a cada transação.
model GemTransaction {
  id          String    @id @default(uuid())
  userId      String
  amount      Int       // Positivo = ganhou | Negativo = gastou
  source      GemSource
  description String?
  referenceId String?   // ID do GemPurchase, UserChest, Achievement, etc.
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("gem_transactions")
}

// ── Compra de Gems com dinheiro real (Stripe) ─────────────────────────────────
// Registra a compra financeira. Gera um GemTransaction com source=PURCHASE.
model GemPurchase {
  id                    String   @id @default(uuid())
  userId                String
  gemsAmount            Int               // Gems creditadas
  priceInCents          Int               // Valor pago em centavos (BRL)
  stripePaymentIntentId String   @unique  // Idempotência — mesma compra não processa 2x
  createdAt             DateTime @default(now())

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("gem_purchases")
}

// ── Assinatura Pro / Max ──────────────────────────────────────────────────────
model Subscription {
  id                   String              @id @default(uuid())
  userId               String              @unique
  stripeSubscriptionId String              @unique
  plan                 SubscriptionPlan                   // PRO ou MAX
  billing              SubscriptionBilling                // MONTHLY ou ANNUAL
  status               SubscriptionStatus  @default(TRIAL)
  trialEndsAt          DateTime?                          // null = sem trial (upgrade direto)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean             @default(false) // Cancelado mas ainda ativo até fim do período
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── Squad ─────────────────────────────────────────────────────────────────────
model Squad {
  id          String    @id @default(uuid())
  name        String
  description String?
  rank        SquadRank @default(GARAGE)   // Progressão permanente da squad
  ownerId     String                        // Quem criou e gerencia (líder)
  maxMembers  Int       @default(5)         // 5 grátis | ilimitado Pro | até 10 no Max
  createdAt   DateTime  @default(now())

  owner           User                  @relation(fields: [ownerId], references: [id])
  members         SquadMember[]
  invites         SquadInvite[]
  weeklySnapshots SquadWeeklySnapshot[]

  @@index([ownerId])
  @@map("squads")
}

// ── Convite de Squad ──────────────────────────────────────────────────────────
// Código curto gerado pelo líder — pode ser compartilhado por link ou copiado.
// Apenas o líder pode gerar convites (validado na camada de negócio).
model SquadInvite {
  id        String    @id @default(uuid())
  squadId   String
  createdBy String                       // userId de quem gerou (sempre o líder)
  code      String    @unique            // Código curto (ex: "XK7-PL2")
  maxUses   Int?                         // null = usos ilimitados (1 por padrão na UI)
  usedCount Int       @default(0)
  expiresAt DateTime?                    // null = sem expiração
  createdAt DateTime  @default(now())

  squad     Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id])

  @@index([squadId])
  @@map("squad_invites")
}

// ── Membro da Squad ───────────────────────────────────────────────────────────
model SquadMember {
  userId    String
  squadId   String
  role      SquadRole @default(MEMBER)
  isActive  Boolean   @default(true)   // false = saiu mas mantém histórico

  // Stats da semana atual (resetados todo domingo à meia-noite via cron)
  weeklyXp      Int      @default(0)
  weeklyCommits Int      @default(0)
  weekStartDate DateTime @db.Date       // Início da semana corrente para este membro

  // Stats acumulados (nunca resetados)
  totalXp      Int      @default(0)
  totalCommits Int      @default(0)

  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@id([userId, squadId])
  @@index([squadId, weeklyXp])   // Leaderboard: ordenar squad por XP da semana
  @@index([squadId, isActive])   // Filtrar apenas membros ativos
  @@map("squad_members")
}

// ── Snapshot semanal da Squad ─────────────────────────────────────────────────
// Gerado toda segunda-feira antes do reset de domingo.
// weeklyXp é zerado após snapshot — o histórico fica aqui.
model SquadWeeklySnapshot {
  id        String   @id @default(uuid())
  squadId   String
  weekStart DateTime @db.Date
  weekEnd   DateTime @db.Date

  // [{userId, position, xp, commits, rankAtTime}]
  rankingData Json

  createdAt DateTime @default(now())

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([squadId, weekStart])
  @@map("squad_weekly_snapshots")
}

// ── Liga — Season (sprint competitivo) ───────────────────────────────────────
// Competição individual de 2 semanas por XP ganho no período.
// Independente do SquadRank (que é progressão permanente da squad).
// Top 3 ao final → promoted = true → entra no tier+1 na próxima season.
// Bottom 3 → relegated → desce para tier-1.
model LigaSeason {
  id           String   @id @default(uuid())
  tier         Int      // 1 = novato ... N = elite
  sprintNumber Int      // #1, #2, #3...
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean  @default(false) // Apenas uma season por tier pode estar ativa

  participants LigaParticipant[]

  @@unique([tier, sprintNumber])
  @@index([isActive])
  @@map("liga_seasons")
}

// ── Liga — Participante por season ───────────────────────────────────────────
// XP acumulado durante a season = fonte para o leaderboard da liga.
// Derivado de XpTransaction WHERE createdAt BETWEEN season.startsAt AND season.endsAt.
// xpEarned é atualizado incrementalmente a cada XpTransaction (cache para performance).
model LigaParticipant {
  id         String     @id @default(uuid())
  seasonId   String
  userId     String

  xpEarned   Int        @default(0) // XP ganho durante este sprint
  finalRank  Int?                   // Posição final — preenchida ao encerrar season
  promoted   Boolean?               // true = top 3, sobe de tier
  relegated  Boolean?               // true = bottom 3, desce de tier

  season     LigaSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@index([seasonId, xpEarned]) // Leaderboard em tempo real: ORDER BY xpEarned DESC
  @@map("liga_participants")
}

// ── Baú do usuário ────────────────────────────────────────────────────────────
// Um registro por baú ganho. openedAt = null significa baú pendente.
// O roll de recompensa ocorre no backend no momento da abertura
// e é salvo em ChestReward antes de retornar ao cliente (anti-cheat).
model UserChest {
  id        String      @id @default(uuid())
  userId    String
  rarity    ChestRarity
  source    ChestSource
  earnedAt  DateTime    @default(now())
  openedAt  DateTime?                   // null = baú ainda fechado

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards   ChestReward[]

  @@index([userId, openedAt]) // "baús pendentes" = WHERE openedAt IS NULL
  @@map("user_chests")
}

// ── Recompensas do baú ────────────────────────────────────────────────────────
// Geradas no momento da abertura — 1 a N recompensas por baú.
// Um baú pode dar XP + coins + um cosmético ao mesmo tempo.
model ChestReward {
  id         String          @id @default(uuid())
  chestId    String
  rewardType ChestRewardType
  amount     Int             @default(0) // Para XP, COINS, GEMS
  cosmeticId String?                     // Preenchido apenas se rewardType = COSMETIC

  chest      UserChest       @relation(fields: [chestId], references: [id], onDelete: Cascade)
  cosmetic   Cosmetic?       @relation(fields: [cosmeticId], references: [id])

  @@index([chestId])
  @@map("chest_rewards")
}

// ── Cosmético (catálogo) ──────────────────────────────────────────────────────
model Cosmetic {
  id          String           @id @default(uuid())
  name        String
  description String?
  category    CosmeticCategory
  rarity      CosmeticRarity
  priceCoins  Int              @default(0)
  priceGems   Int              @default(0)
  isAvailable Boolean          @default(true)  // Soft-delete / itens sazonais

  owners        UserCosmetic[]
  equippedBy    UserEquippedCosmetic[]
  rewardedBy    Achievement[]
  chestRewards  ChestReward[]

  @@map("cosmetics")
}

// ── Inventário do usuário ─────────────────────────────────────────────────────
model UserCosmetic {
  userId         String
  cosmeticId     String
  obtainedSource CosmeticObtainedSource
  obtainedAt     DateTime               @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@id([userId, cosmeticId])
  @@map("user_cosmetics")
}

// ── Cosméticos equipados ──────────────────────────────────────────────────────
// @@id([userId, category]) garante no banco: apenas 1 item por categoria por usuário.
// Trocar chapéu = UPDATE nesta linha, não INSERT novo.
model UserEquippedCosmetic {
  userId     String
  category   CosmeticCategory
  cosmeticId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@id([userId, category])
  @@map("user_equipped_cosmetics")
}

// ── Conquistas (catálogo) ─────────────────────────────────────────────────────
model Achievement {
  id          String              @id @default(uuid())
  title       String
  description String
  category    AchievementCategory
  rarity      AchievementRarity   @default(COMMON)
  metricType  MetricType
  targetValue Int                 // Meta (ex: 30 para "30 dias de streak")
  isHidden    Boolean             @default(false)  // Easter eggs ficam invisíveis

  // Recompensas ao desbloquear
  rewardXp         Int       @default(0)
  rewardCoins      Int       @default(0)
  rewardGems       Int       @default(0)
  rewardCosmeticId String?
  rewardCosmetic   Cosmetic? @relation(fields: [rewardCosmeticId], references: [id])

  winners          UserAchievement[]
  progressTrackers AchievementProgress[]

  @@map("achievements")
}

// ── Conquistas desbloqueadas ──────────────────────────────────────────────────
model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

// ── Progresso em conquistas ───────────────────────────────────────────────────
// Para conquistas incrementais — mostra "18 / 30" antes de desbloquear.
model AchievementProgress {
  userId        String
  achievementId String
  currentValue  Int      @default(0)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("achievement_progress")
}

// ── Desafio diário (catálogo) ─────────────────────────────────────────────────
model DailyChallenge {
  id          String     @id @default(uuid())
  title       String
  description String
  metricType  MetricType
  targetValue Int

  // Recompensas
  rewardXp    Int @default(0)
  rewardCoins Int @default(0)
  rewardGems  Int @default(0)

  // activeDate preenchida → desafio fixo para aquele dia
  // activeDate null       → pool rotativo (sorteado pelo sistema)
  activeDate  DateTime? @db.Date

  participants UserDailyChallenge[]

  @@map("daily_challenges")
}

// ── Progresso do usuário no desafio diário ────────────────────────────────────
model UserDailyChallenge {
  userId      String
  challengeId String
  date        DateTime  @db.Date    // Data de participação
  currentValue Int      @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?             // Quando finalizou o desafio
  claimedAt   DateTime?             // Quando clicou em "coletar" — null = não coletado ainda

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId, date])
  @@index([userId, date])
  @@index([userId, isCompleted, claimedAt]) // "desafios concluídos mas não coletados"
  @@map("user_daily_challenges")
}

// ── Feed de eventos ───────────────────────────────────────────────────────────
// Gerado automaticamente pelos serviços quando eventos notáveis ocorrem.
// Alimenta a tela de feed — mostra atividade da squad e do mundo.
// payload é JSONB livre — schema depende do type:
//   STREAK_MILESTONE → { streak: 30 }
//   ACHIEVEMENT      → { achievementId: "...", title: "..." }
//   CHEST_LEGENDARY  → { itemName: "Espada Plasma" }
//   LIGA_PROMOTED    → { fromTier: 2, toTier: 3 }
model FeedEvent {
  id         String          @id @default(uuid())
  userId     String
  type       FeedEventType
  payload    Json            @default("{}")
  visibility FeedVisibility  @default(SQUAD)
  createdAt  DateTime        @default(now())

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])          // Feed global paginado por data
  @@index([visibility, createdAt]) // Filtrar por visibilidade
  @@map("feed_events")
}
