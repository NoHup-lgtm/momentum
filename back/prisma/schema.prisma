// momentum · schema.prisma
// stack: NestJS + Prisma 7 + Neon (PostgreSQL)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL definida via prisma.config.ts → process.env.DATABASE_URL
}

// ══════════════════════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════════════════════

enum AuthProvider {
  GITHUB
}

// ── Progressão individual ─────────────────────────────────────────────────────
enum UserRank {
  INIT
  BUILD
  DEPLOY
  SENIOR
  ARCHITECT
  LEGEND
}

// ── Progressão coletiva da squad ──────────────────────────────────────────────
enum SquadRank {
  GARAGE
  BOOTSTRAPPED
  STARTUP
  UNICORN
  BIG_TECH
  SILICON_VALLEY
}

enum SquadRole {
  OWNER
  MEMBER
}

// ── Cosméticos ────────────────────────────────────────────────────────────────
enum CosmeticCategory {
  HAT
  SHIRT
  GLASSES
  ACCESSORY
  BACKGROUND
}

enum CosmeticRarity {
  COMMON
  RARE
  PREMIUM
  LEGENDARY
}

enum CosmeticObtainedSource {
  PURCHASED_COINS
  PURCHASED_GEMS
  ACHIEVEMENT_REWARD
  EVENT_REWARD
}

// ── Conquistas ────────────────────────────────────────────────────────────────
enum AchievementCategory {
  STREAK       // Ofensiva (dias consecutivos)
  COMMIT       // Volume de commits
  PR           // Pull Requests e colaboração
  RANK         // Atingir determinado rank
  SOCIAL       // Posição e interação na squad
  COLLECTION   // Itens comprados ou ganhos
  HIDDEN       // Easter eggs — invisíveis até serem desbloqueados
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

// ── Métricas — usadas em desafios e conquistas ────────────────────────────────
enum MetricType {
  DAILY_COMMITS              // Commits em um único dia
  DAILY_PRS                  // Pull Requests em um único dia
  STREAK_DAYS                // Dias consecutivos com commit
  MAX_STREAK                 // Maior streak atingida (all-time)
  WEEKLY_COMMITS             // Commits na semana corrente
  TOTAL_XP                   // XP acumulado total (conquistas de longo prazo)
  OPEN_SOURCE_CONTRIBUTIONS  // Contribuições para repos de terceiros
}

// ── Fontes de XP ──────────────────────────────────────────────────────────────
enum XpSource {
  DAILY_COMMIT        // +15 XP por commit do dia
  STREAK_MILESTONE    // Bônus por marco de streak (7d, 30d, 100d…)
  DAILY_CHALLENGE     // Desafio diário concluído
  ACHIEVEMENT         // Conquista desbloqueada
  RANK_UP_BONUS       // Bônus ao subir de rank
  SQUAD_BONUS         // Bônus por posição no ranking semanal
  CHECKIN             // XP de check-in manual (qualidade do dia)
}

// ── Fontes de Coins ───────────────────────────────────────────────────────────
enum CoinSource {
  DAILY_COMMIT        // Coins por commit do dia
  DAILY_CHALLENGE     // Desafio diário
  ACHIEVEMENT         // Conquista
  STREAK_MILESTONE    // Marco de streak
  SQUAD_TOP3          // Top 3 no ranking semanal
  PURCHASE_ITEM       // Compra de item na loja (valor negativo)
}

// ── Status do streak freeze ───────────────────────────────────────────────────
enum FreezeStatus {
  ACTIVE    // Freeze ativo — ainda protegendo o dia
  CONSUMED  // Dia passou, freeze foi consumido com sucesso
}

// ── Status da assinatura Pro ──────────────────────────────────────────────────
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE   // Pagamento falhou mas ainda no período de graça
  CANCELED
  EXPIRED
}

// ══════════════════════════════════════════════════════════════════════════════
// MODELS
// ══════════════════════════════════════════════════════════════════════════════

// ── Waitlist da landing page ──────────────────────────────────────────────────
model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String?  // "hero" | "finalcta" — de qual seção da LP veio
  createdAt DateTime @default(now())

  @@map("waitlist")
}

// ── Usuário ───────────────────────────────────────────────────────────────────
model User {
  id           String       @id @default(uuid())

  // GitHub OAuth
  githubId     String       @unique  // ID numérico imutável da conta GitHub
  githubLogin  String       @unique  // username GitHub (ex: "dev_marcos")
  accessToken  String                // OAuth token — criptografar antes de persistir
  avatarUrl    String?               // Foto de perfil do GitHub
  email        String?      @unique  // Email público do GitHub

  // Exibição no app
  displayName  String?               // Nome customizável dentro do app
  avatarVariant Int         @default(0)   // Índice do pixel avatar (0–5)
  timezone     String       @default("America/Sao_Paulo")

  // Auth
  authProvider AuthProvider @default(GITHUB)

  // Progressão
  rank         UserRank     @default(INIT)
  level        Int          @default(1)   // Nível numérico baseado em totalXp
  totalXp      Int          @default(0)

  // Moedas
  coins        Int          @default(0)
  gems         Int          @default(0)

  // Ofensiva
  currentStreak  Int        @default(0)
  maxStreak      Int        @default(0)
  lastCommitDate DateTime?  @db.Date  // Última data com commit válido para streak
  streakFreezes  Int        @default(1)

  // Plano
  isPro            Boolean  @default(false)
  stripeCustomerId String?  @unique  // Para billing Pro via Stripe

  // Preferências de notificação
  notifyStreakReminder Boolean @default(true)   // Aviso antes de meia-noite
  notifySquadActivity  Boolean @default(true)   // Membro da squad commitou
  notifyRankUp         Boolean @default(false)  // Alguém subiu de rank na squad
  notifyWeeklyRecap    Boolean @default(true)   // Resumo semanal no domingo

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relacionamentos
  commits             Commit[]
  streakFreezeUsages  StreakFreezeUsage[]
  xpTransactions      XpTransaction[]
  coinTransactions    CoinTransaction[]
  gemPurchases        GemPurchase[]
  subscription        Subscription?
  squadMemberships    SquadMember[]
  squadsOwned         Squad[]
  squadInvitesCreated SquadInvite[]
  devices             UserDevice[]
  cosmetics           UserCosmetic[]
  equippedCosmetics   UserEquippedCosmetic[]
  rankHistory         RankHistory[]
  achievements        UserAchievement[]
  achievementProgress AchievementProgress[]
  dailyChallenges     UserDailyChallenge[]

  @@map("users")
}

// ── Dispositivos do usuário (push notifications) ──────────────────────────────
model UserDevice {
  id         String   @id @default(uuid())
  userId     String
  pushToken  String   @unique  // Token Expo / FCM / APNS
  platform   String            // "ios" | "android"
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_devices")
}

// ── Commit verificado via GitHub API ──────────────────────────────────────────
// Um registro por PushEvent processado. O primeiro commit do dia (dentro da
// janela válida, considerando timezone + grace period até 1h da manhã) ativa
// a ofensiva. Os demais acumulam XP mas não contam para streak.
model Commit {
  id            String   @id @default(uuid())
  userId        String

  // Dados do GitHub
  commitSha     String            // SHA do commit
  repoName      String            // "momentum"
  repoFullName  String            // "dev_marcos/momentum"
  branch        String?           // "main" | "feat/login"
  commitMessage String?
  committedAt   DateTime          // Timestamp UTC do commit no GitHub
  isPrivateRepo Boolean  @default(false)

  // Processamento interno
  xpGained         Int     @default(15)
  coinsGained      Int     @default(5)
  countedForStreak Boolean @default(false)  // true apenas no 1º commit válido do dia
  processedAt      DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commitSha])        // Mesmo SHA nunca entra duas vezes
  @@index([userId, committedAt])       // Query: "usuário commitou hoje?"
  @@index([userId, countedForStreak])  // Filtrar commits que ativaram streak
  @@map("commits")
}

// ── Uso de streak freeze ──────────────────────────────────────────────────────
model StreakFreezeUsage {
  id            String       @id @default(uuid())
  userId        String
  protectedDate DateTime     @db.Date     // Qual dia o freeze salvou
  status        FreezeStatus @default(ACTIVE)
  activatedAt   DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, protectedDate])  // Máximo 1 freeze por dia por usuário
  @@index([userId])
  @@map("streak_freeze_usages")
}

// ── Histórico de rank ─────────────────────────────────────────────────────────
// Cada linha = uma mudança de rank. Dispara a animação de rank-up no app.
// Permite mostrar no perfil: "virou Senior em 15 mai".
model RankHistory {
  id        String   @id @default(uuid())
  userId    String
  fromRank  UserRank
  toRank    UserRank
  changedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@map("rank_history")
}

// ── Histórico de XP ───────────────────────────────────────────────────────────
// Append-only. Nunca deletar. Fonte da verdade para auditoria de progressão.
model XpTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int               // Positivo = ganhou | Negativo = perdeu
  source      XpSource
  description String?           // "Ofensiva de 30 dias!" | "Top 1 na squad"
  referenceId String?           // ID do commit, achievement, etc. que gerou o XP
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

// ── Histórico de Coins ────────────────────────────────────────────────────────
model CoinTransaction {
  id          String     @id @default(uuid())
  userId      String
  amount      Int                // Positivo = ganhou | Negativo = gastou
  source      CoinSource
  description String?
  referenceId String?
  createdAt   DateTime   @default(now())

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("coin_transactions")
}

// ── Compra de Gems (dinheiro real → Stripe) ───────────────────────────────────
model GemPurchase {
  id                    String   @id @default(uuid())
  userId                String
  gemsAmount            Int               // Gems creditadas
  priceInCents          Int               // Valor pago em centavos (BRL)
  stripePaymentIntentId String   @unique  // Idempotência — mesma compra não processa 2x
  createdAt             DateTime @default(now())

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("gem_purchases")
}

// ── Assinatura Pro ────────────────────────────────────────────────────────────
model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── Squad ─────────────────────────────────────────────────────────────────────
model Squad {
  id          String    @id @default(uuid())
  name        String
  description String?
  rank        SquadRank @default(GARAGE)
  ownerId     String                      // Quem criou e gerencia
  maxMembers  Int       @default(5)       // 5 grátis | ilimitado Pro
  createdAt   DateTime  @default(now())

  owner           User                @relation(fields: [ownerId], references: [id])
  members         SquadMember[]
  invites         SquadInvite[]
  weeklySnapshots SquadWeeklySnapshot[]

  @@index([ownerId])
  @@map("squads")
}

// ── Convite de Squad ──────────────────────────────────────────────────────────
// Substitui o inviteCode estático. Cada convite tem controle de uso e expiração.
model SquadInvite {
  id        String    @id @default(uuid())
  squadId   String
  createdBy String                       // userId de quem gerou
  code      String    @unique            // Código curto (ex: "XK7-PL2")
  maxUses   Int?                         // null = usos ilimitados
  usedCount Int       @default(0)
  expiresAt DateTime?                    // null = sem expiração
  createdAt DateTime  @default(now())

  squad     Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [createdBy], references: [id])

  @@index([squadId])
  @@map("squad_invites")
}

// ── Membro da Squad ───────────────────────────────────────────────────────────
model SquadMember {
  userId    String
  squadId   String
  role      SquadRole @default(MEMBER)
  isActive  Boolean   @default(true)   // false = saiu mas mantém histórico

  // Stats da semana atual (resetados todo domingo à meia-noite)
  weeklyXp      Int      @default(0)
  weeklyCommits Int      @default(0)
  weekStartDate DateTime @db.Date       // Início da semana corrente para este membro

  // Stats acumulados (nunca resetados)
  totalXp      Int      @default(0)
  totalCommits Int      @default(0)

  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@id([userId, squadId])
  @@index([squadId, weeklyXp])   // Leaderboard: ordenar squad por XP da semana
  @@index([squadId, isActive])   // Filtrar apenas membros ativos
  @@map("squad_members")
}

// ── Snapshot semanal da Squad ─────────────────────────────────────────────────
// Gerado toda segunda-feira antes do reset de domingo.
// weeklyXp é zerado após snapshot — o histórico fica aqui.
model SquadWeeklySnapshot {
  id        String   @id @default(uuid())
  squadId   String
  weekStart DateTime @db.Date
  weekEnd   DateTime @db.Date

  // [{userId, position, xp, commits, rankAtTime}]
  rankingData Json

  createdAt DateTime @default(now())

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([squadId, weekStart])
  @@map("squad_weekly_snapshots")
}

// ── Cosmético (catálogo) ──────────────────────────────────────────────────────
model Cosmetic {
  id          String           @id @default(uuid())
  name        String
  description String?
  category    CosmeticCategory
  rarity      CosmeticRarity
  priceCoins  Int              @default(0)
  priceGems   Int              @default(0)
  isAvailable Boolean          @default(true)  // Soft-delete / itens sazonais

  owners     UserCosmetic[]
  equippedBy UserEquippedCosmetic[]
  rewardedBy Achievement[]

  @@map("cosmetics")
}

// ── Inventário do usuário ─────────────────────────────────────────────────────
model UserCosmetic {
  userId         String
  cosmeticId     String
  obtainedSource CosmeticObtainedSource
  obtainedAt     DateTime               @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@id([userId, cosmeticId])
  @@map("user_cosmetics")
}

// ── Cosméticos equipados ──────────────────────────────────────────────────────
// @@id([userId, category]) garante no banco: apenas 1 item por categoria por usuário.
// Trocar chapéu = UPDATE nesta linha, não INSERT novo.
model UserEquippedCosmetic {
  userId     String
  category   CosmeticCategory
  cosmeticId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmetic Cosmetic @relation(fields: [cosmeticId], references: [id], onDelete: Cascade)

  @@id([userId, category])
  @@map("user_equipped_cosmetics")
}

// ── Conquistas (catálogo) ─────────────────────────────────────────────────────
model Achievement {
  id          String              @id @default(uuid())
  title       String
  description String
  category    AchievementCategory
  rarity      AchievementRarity   @default(COMMON)
  metricType  MetricType
  targetValue Int                 // Meta (ex: 30 para "30 dias de streak")
  isHidden    Boolean             @default(false)  // Easter eggs ficam invisíveis

  // Recompensas ao desbloquear
  rewardXp         Int      @default(0)
  rewardCoins      Int      @default(0)
  rewardCosmeticId String?
  rewardCosmetic   Cosmetic? @relation(fields: [rewardCosmeticId], references: [id])

  winners          UserAchievement[]
  progressTrackers AchievementProgress[]

  @@map("achievements")
}

// ── Conquistas desbloqueadas ──────────────────────────────────────────────────
model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("user_achievements")
}

// ── Progresso em conquistas ───────────────────────────────────────────────────
// Para conquistas incrementais — mostra "18 / 30" antes de desbloquear.
model AchievementProgress {
  userId        String
  achievementId String
  currentValue  Int      @default(0)
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([userId, achievementId])
  @@map("achievement_progress")
}

// ── Desafio diário (catálogo) ─────────────────────────────────────────────────
model DailyChallenge {
  id          String     @id @default(uuid())
  title       String
  description String
  metricType  MetricType
  targetValue Int

  // Recompensas
  rewardXp    Int @default(0)
  rewardCoins Int @default(0)
  rewardGems  Int @default(0)

  // activeDate preenchida → desafio fixo para aquele dia
  // activeDate null       → pool rotativo (sorteado pelo sistema)
  activeDate  DateTime? @db.Date

  participants UserDailyChallenge[]

  @@map("daily_challenges")
}

// ── Progresso do usuário no desafio diário ────────────────────────────────────
model UserDailyChallenge {
  userId      String
  challengeId String
  date        DateTime  @db.Date   // Data de participação
  currentValue Int      @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@id([userId, challengeId, date])
  @@index([userId, date])
  @@map("user_daily_challenges")
}
