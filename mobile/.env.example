# Client ID do GitHub OAuth App (Settings → Developer settings → OAuth Apps)
EXPO_PUBLIC_GITHUB_CLIENT_ID=""

# URL da API. Em dev pode deixar vazio: o app detecta o IP da LAN pelo Metro
# e usa a porta 3000 automaticamente. Defina só se a API estiver em outro host.
# EXPO_PUBLIC_API_URL="http://192.168.0.12:3000"
